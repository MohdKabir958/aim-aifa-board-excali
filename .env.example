# Copy to `.env.development.local` (repo root) and fill in. Do not commit real values.

# --- Frontend (Vite; prefix VITE_) ---
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_...   (browser-safe; from Clerk API keys)
#
# Server only — never prefix with VITE_ (would leak into the client bundle):
# CLERK_SECRET_KEY=sk_test_or_sk_live_...
# VITE_APP_AI_BACKEND=https://your-api.example.com
# VITE_APP_PORT=3001
#
# Dashboard + saved boards (`/dashboard`, `/board/:id`) call the same API as AI features.
# Set CORS_ORIGINS to include your app origin (e.g. http://localhost:3000 for Vite dev).

# --- AI backend (Node reads these from repo root or Render/Fly env) ---
# NODE_ENV=production
# AI_BACKEND_PORT=3016
# AI_BACKEND_HOST=0.0.0.0
# TRUST_PROXY=1
# CORS_ORIGINS=https://your-app.example.com,https://www.your-app.example.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# CLERK_SECRET_KEY=sk_live_or_test_...
# NEON_DATABASE_URL=postgresql://...
#
# Optional: max gzip-compressed scene size per board save (bytes)
# BOARD_SCENE_MAX_GZIP_BYTES=12582912
