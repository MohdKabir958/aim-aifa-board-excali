# Copy to `.env.development.local` (repo root) and fill in. Do not commit real values.

# --- Frontend (Vite; prefix VITE_) ---
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_or_test_...
# VITE_APP_AI_BACKEND=https://your-api.example.com
# VITE_APP_PORT=3001

# --- AI backend (Node reads these from repo root or Render/Fly env) ---
# NODE_ENV=production
# AI_BACKEND_PORT=3016
# AI_BACKEND_HOST=0.0.0.0
# TRUST_PROXY=1
# CORS_ORIGINS=https://your-app.example.com,https://www.your-app.example.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# CLERK_SECRET_KEY=sk_live_or_test_...
# NEON_DATABASE_URL=postgresql://...
